node_modules/
dist/
.wrangler/
*.log
.env
worker/public/*
!worker/public/.gitkeep
.reck-worktrees/
.claude/
.superpowers/

# VSCode: ship the checked-in debug config (launch.json + tasks.json, see
# docs/vscode-debugging.md) but ignore machine-specific personal settings
# so contributors don't accidentally commit local tweaks.
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json

# Archived / parked code (kept on disk, not tracked, not shipped)
legacy-v1/
share-reck-connect/
mini-satellite/

# macOS Finder metadata
.DS_Store
**/.DS_Store

# macOS AppleDouble metadata (._foo sidecars on non-HFS volumes)
**/._*

# Microsoft Office lock files (created while a doc is open)
**/~$*
