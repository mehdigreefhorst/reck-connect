{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "vite-and-tsc-w",
      "type": "shell",
      "command": "pnpm dev:bg",
      "options": {
        "cwd": "${workspaceFolder}/satellite",
        "env": {
          "VITE_RECK_STATION_ROOT": "/Users/reck-connect/projects",
          "RECK_STATION_ROOT": "/Users/reck-connect/projects"
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "owner": "tsc-watch",
        "fileLocation": ["relative", "${workspaceFolder}/satellite"],
        "pattern": {
          "regexp": "^([^\\s].*)\\((\\d+|\\,\\d+|\\d+,\\d+,\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(TS\\d+)\\s*:\\s*(.*)$",
          "file": 1,
          "location": 2,
          "severity": 3,
          "code": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*\\d{1,2}:\\d{2}:\\d{2}\\s.*Starting compilation",
          "endsPattern": "^\\s*\\d{1,2}:\\d{2}:\\d{2}\\s.*Watching for file changes"
        }
      }
    }
  ]
}
