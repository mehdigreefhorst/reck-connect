# satellite.env — Reck Connect satellite-side configuration.
#
# This file is the single source of truth for every per-deployment
# value the satellite install + build needs. ops/install-satellite.sh
# and ops/build-app.sh both source it before doing anything.
#
# Edit the placeholders below for your station, then run:
#
#   cp ops/satellite.env.example ~/.config/reck/satellite.env
#   chmod 0600 ~/.config/reck/satellite.env
#   ${EDITOR:-vi} ~/.config/reck/satellite.env
#
# (install-satellite.sh creates the file from this template on first
# run if it doesn't already exist, then exits asking you to fill it
# in. So you can also just run install-satellite.sh once and follow
# the prompt.)
#
# Required for both install AND build.

# SSH user on the station. This is the account the watchdog logs in
# as via sshfs. Examples:
#   reck-connect — upstream macOS-station convention (dedicated user
#                  created by ops/bootstrap-reck-user.sh on the station)
#   root_user    — your own admin user on a custom Linux station
RECK_STATION_USER=reck-connect

# Managed-projects root path on the station. The satellite app uses
# this to:
#   - mount projects via sshfs at ~/reck/projects/
#   - translate station-side cwds to local mount paths
#   - rsync new project copies to the station
#   - default the "Add Project" dialog
# Examples:
#   /Users/reck-connect/projects    — upstream macOS convention
#   /home/root_user/coding_projects — a custom Linux layout
RECK_STATION_ROOT=/Users/reck-connect/projects

# Station's hostname (Tailscale MagicDNS name or tailnet IP).
# install-satellite.sh prompts for this if not set; setting it here
# makes the install fully unattended.
STATION_HOST=your-station

# (Optional) Bearer token for the station daemon. If you set this
# and pass --write-settings to install-satellite.sh, the satellite
# app's first-launch settings get seeded automatically — skipping
# the manual paste step. Lives in this file at mode 0600.
# Leave commented to enter the token via the satellite UI on first
# launch instead.
#RECK_SATELLITE_TOKEN=
